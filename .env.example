VITE_MARKET_RADAR_API_URL=/api/market-radar

# 美股風險偏好：Alpha Vantage GLOBAL_QUOTE for SPY / QQQ
# 更新頻率與即時性依 Alpha Vantage 方案而定
ALPHA_VANTAGE_API_KEY=

# 台股外資態度：TWSE 官方 OpenAPI，收盤後更新
TWSE_FOREIGN_FLOW_URL=https://openapi.twse.com.tw/v1/fund/T86

# 港股資金流：請接 HKEX 授權 Stock Connect API 或付費資料商代理端點
# 端點需回傳 { netFlowHkd, status?, source?, reliability? }
HKEX_STOCK_CONNECT_FLOW_URL=

# 前端 GA4 事件追蹤 Measurement ID，不是密鑰，可以暴露在瀏覽器
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 後台登入保護
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Analytics 4 Data API
# GA4_PROPERTY_ID 請填 GA4 資源 ID，不是 G- 開頭 Measurement ID
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=

# 二選一即可：
# 1. 將 service account private_key 原文貼上，換行可用 \n
GA4_PRIVATE_KEY=
# 2. 或將 private_key 做 base64 後放這裡，較適合 Vercel 環境變數
GA4_PRIVATE_KEY_BASE64=
