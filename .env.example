VITE_MARKET_RADAR_API_URL=/api/market-radar

# 美股風險偏好：Alpha Vantage GLOBAL_QUOTE for SPY / QQQ
# 更新頻率與即時性依 Alpha Vantage 方案而定
ALPHA_VANTAGE_API_KEY=

# 台股外資態度：TWSE 官方 OpenAPI，收盤後更新
TWSE_FOREIGN_FLOW_URL=https://openapi.twse.com.tw/v1/fund/T86

# 港股資金流：請接 HKEX 授權 Stock Connect API 或付費資料商代理端點
# 端點需回傳 { netFlowHkd, status?, source?, reliability? }
HKEX_STOCK_CONNECT_FLOW_URL=

# 前端 GA4 事件追蹤 Measurement ID，不是密鑰，可以暴露在瀏覽器
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 後台登入保護
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_SECRET=your_long_private_session_secret

# Google Analytics 4 Data API
# GA4_PROPERTY_ID 請填 GA4 資源 ID，不是 G- 開頭 Measurement ID
GA4_PROPERTY_ID=123456789

# 建議使用 OAuth 模式：用具有 GA4 權限的 Google 帳號授權一次
GA4_OAUTH_CLIENT_ID=google_oauth_client_id
GA4_OAUTH_CLIENT_SECRET=google_oauth_client_secret
GA4_OAUTH_REFRESH_TOKEN=google_oauth_refresh_token
# 可選：若 Vercel domain 與正式站不同，請明確指定 callback
GA4_OAUTH_REDIRECT_URI=https://xqcamille.com/api/admin/ga4/oauth-callback

# 備援 Service Account 模式
GA4_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# 不要把 service-account.json 或 private_key 原文 commit 到 GitHub
GA4_PRIVATE_KEY_BASE64=base64_encoded_private_key
